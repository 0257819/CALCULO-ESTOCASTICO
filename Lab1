print("==========================================================================================")
print("### Resultados de Parámetros Anualizados del GBM ###")
print(f"{'Parámetro':<30} {'Valor':<20}")
print(f"{'------------------------------':<30} {'--------------------':<20}")
print(f"{'Mu_b (Media Anualizada)':<30} {mu_b:<20.10f}")
